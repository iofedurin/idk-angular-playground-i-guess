{
  "name": "playground",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "backend": "node fake-backend/server.mjs",
    "dev": "concurrently \"bun run start\" \"bun run backend\"",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint:arch": "steiger ./src/app && bash scripts/lint-app-scoped.sh",
    "lint:app-scoped": "bash scripts/lint-app-scoped.sh"
  },
  "private": true,
  "packageManager": "bun@1.3.9",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@ngrx/signals": "^21.1.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.5",
    "@angular/cli": "^21.2.5",
    "@angular/compiler-cli": "^21.2.0",
    "@feature-sliced/steiger-plugin": "^0.5.7",
    "@tailwindcss/postcss": "^4.1.12",
    "@types/ws": "^8.18.1",
    "concurrently": "^9.2.1",
    "daisyui": "^5.5.19",
    "jsdom": "^28.0.0",
    "json-server": "^1.0.0-beta.15",
    "postcss": "^8.5.3",
    "prettier": "^3.8.1",
    "steiger": "^0.5.11",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8",
    "ws": "^8.20.0"
  }
}
